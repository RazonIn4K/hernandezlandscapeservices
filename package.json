{
  "name": "hernandezlandscapeservices",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "npm run build-css",
    "build-css": "tailwindcss -i ./src/input.css -o ./assets/css/styles.css --minify",
    "watch-css": "tailwindcss -i ./src/input.css -o ./assets/css/styles.css --watch",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ci": "npm run media:check && npm run media:budget && npm run seo:check && npm run nap:check && playwright test --reporter=dot",
    "dev": "npm run watch-css",
    "media:update": "node scripts/update-media.mjs",
    "media:check": "node scripts/update-media.mjs --check",
    "media:budget": "node scripts/check-media-budget.mjs",
    "seo:check": "node scripts/check-seo.mjs",
    "nap:check": "node scripts/verify-nap.mjs",
    "publish:prepare": "node scripts/prepare-publish.mjs",
    "publish:check-layout": "node scripts/check-publish-layout.mjs",
    "submit-indexnow": "node scripts/submit-indexnow.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RazonIn4K/hernandezlandscapeservices.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/RazonIn4K/hernandezlandscapeservices/issues"
  },
  "homepage": "https://github.com/RazonIn4K/hernandezlandscapeservices#readme",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1",
    "serve": "^14.2.6",
    "tailwindcss": "^3.4.19"
  }
}
