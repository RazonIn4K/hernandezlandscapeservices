    {
      "@type": "FAQPage",
      "@id": "https://hernandezlandscapeservices.com/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Do you provide free estimates for tree removal in DeKalb?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, we provide free, no-obligation estimates for all tree removal, tree trimming, and landscaping projects in DeKalb County and surrounding areas."
          }
        },
        {
          "@type": "Question",
          "name": "Is Hernandez Landscape & Tree Service licensed and insured?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, we are a fully licensed and insured LLC (Auth #13934835) protecting your property during all tree and landscaping work."
          }
        },
        {
          "@type": "Question",
          "name": "What areas do you serve outside of DeKalb?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our primary service areas are DeKalb and Sycamore. We also serve Cortland, Malta, Genoa, Kingston, Rochelle, Hinckley, St. Charles, and West Chicago."
          }
        },
        {
          "@type": "Question",
          "name": "Do you offer emergency tree removal services?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, we offer 24/7 emergency tree service for fallen or hazardous trees that pose an immediate threat to your home or property."
          }
        },
        {
          "@type": "Question",
          "name": "Do you provide snow removal for residential properties?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, we offer seasonal snow removal services for both residential and commercial properties in the DeKalb area, subject to availability."
          }
        }
      ]
